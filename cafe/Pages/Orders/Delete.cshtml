@page
@model cafe.Pages.Orders.DeleteModel
@{
    ViewData["Title"] = "Удаление заказа";
}

<h1>Удаление заказа</h1>

<div class="alert alert-danger">
    <h3>Вы уверены, что хотите удалить этот заказ?</h3>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Название заказа</dt>
        <dd class="col-sm-10">@Model.Order.Name</dd>

        <dt class="col-sm-2">Номер заказа</dt>
        <dd class="col-sm-10">@Model.Order.NumberOrder</dd>

        <dt class="col-sm-2">Состав заказа</dt>
        <dd class="col-sm-10">@Model.Order.OrderContains</dd>

        <dt class="col-sm-2">Общая сумма</dt>
        <dd class="col-sm-10">@Model.Order.TotalAmount.ToString("C")</dd>

        <dt class="col-sm-2">Статус</dt>
        <dd class="col-sm-10">@Model.Order.Status</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Order.Id" />
        <button type="submit" class="btn btn-danger">Удалить</button>
        <a asp-page="./Index" class="btn btn-secondary">Отмена</a>
    </form>
</div>  