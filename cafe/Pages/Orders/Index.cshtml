@page
@model cafe.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Заказы";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>📦 Заказы</h1>
    <a asp-page="Create" class="btn btn-primary btn-lg">
        ➕ Создать заказ
    </a>
</div>

@if (!Model.Orders.Any())
{
    <div class="alert alert-info text-center">
        <h4>Нет заказов</h4>
        <p>Нажмите "Создать заказ", чтобы добавить первый заказ.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var order in Model.Orders)
        {
            <div class="col-md-4 mb-4">
                <div class="card card-hover h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title text-primary">@order.Name</h5>
                            <span class="badge bg-secondary">№ @order.NumberOrder</span>
                        </div>
                        <hr />
                        <p class="card-text">
                            <strong>🍽️ Состав:</strong> @order.OrderContains<br />
                            <strong>💰 Сумма:</strong> <span class="fw-bold text-success">@order.TotalAmount.ToString("C")</span><br />
                            <strong>📌 Статус:</strong>
                            <span class="badge @(order.Status == "Выполнен" ? "bg-success" : order.Status == "Отменён" ? "bg-danger" : "bg-warning")">
                                @order.Status
                            </span>
                        </p>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-page="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-warning flex-grow-1">
                            ✏️ Изменить
                        </a>
                        <a asp-page="Delete" asp-route-id="@order.Id" class="btn btn-sm btn-danger flex-grow-1">
                            🗑️ Удалить
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}