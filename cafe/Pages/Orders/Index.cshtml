@page
@model cafe.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Заказы";
}

<h1>Заказы</h1>
<p>
    <a asp-page="Create" class="btn btn-primary">Создать новый заказ</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Название заказа</th>
            <th>Номер заказа</th>
            <th>Состав заказа</th>
            <th>Общая сумма</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td>@order.Name</td>
                <td>@order.NumberOrder</td>
                <td>@order.OrderContains</td>
                <td>@order.TotalAmount.ToString("C")</td>
                <td>@order.Status</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-warning">Изменить</a>
                    <a asp-page="Delete" asp-route-id="@order.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>