@page
@model cafe.Pages.Clients.EditModel
@{
    ViewData["Title"] = "Редактировать клиента";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-warning">
                <h3 class="mb-0">✏️ Редактирование клиента</h3>
            </div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Client.Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Client.NickName" class="form-label fw-bold">NickName</label>
                        <input asp-for="Client.NickName" class="form-control" />
                        <span asp-validation-for="Client.NickName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Client.Fullname" class="form-label fw-bold">Полное имя</label>
                        <input asp-for="Client.Fullname" class="form-control" />
                        <span asp-validation-for="Client.Fullname" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Client.Email" class="form-label fw-bold">Email</label>
                        <input asp-for="Client.Email" class="form-control" />
                        <span asp-validation-for="Client.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Client.BonusPoint" class="form-label fw-bold">Бонусные баллы</label>
                        <input asp-for="Client.BonusPoint" class="form-control" />
                        <span asp-validation-for="Client.BonusPoint" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <button type="submit" class="btn btn-primary">💾 Сохранить</button>
                        <a asp-page="Index" class="btn btn-secondary">❌ Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}