@page
@model cafe.Pages.Clients.IndexModel
@{
    ViewData["Title"] = "Клиенты";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>👥 Клиенты</h1>
    <a asp-page="Create" class="btn btn-primary btn-lg">
        ➕ Добавить клиента
    </a>
</div>

@if (!Model.Clients.Any())
{
    <div class="alert alert-info text-center">
        <h4>Нет клиентов</h4>
        <p>Нажмите "Добавить клиента", чтобы создать первую запись.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var client in Model.Clients)
        {
            <div class="col-md-4 mb-4">
                <div class="card card-hover h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title text-primary">@client.NickName</h5>
                            <span class="badge bg-info rounded-pill">⭐ @client.BonusPoint</span>
                        </div>
                        <h6 class="card-subtitle mb-2 text-muted">@client.Fullname</h6>
                        <hr />
                        <p class="card-text">
                            <strong>📧 Email:</strong> @client.Email
                        </p>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-page="Edit" asp-route-id="@client.Id" class="btn btn-sm btn-warning flex-grow-1">
                            ✏️ Изменить
                        </a>
                        <a asp-page="Delete" asp-route-id="@client.Id" class="btn btn-sm btn-danger flex-grow-1">
                            🗑️ Удалить
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}